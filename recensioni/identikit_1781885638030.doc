<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Identikit Libro Letto</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 40px 20px;
        }

        .container {
            background-color: #ffffff;
            width: 100%;
            max-width: 850px;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }

        .header-title {
            text-align: center;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 30px;
            color: #000000;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .grid-2col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        @media (max-width: 600px) {
            .grid-2col {
                grid-template-columns: 1fr;
            }
        }

        .input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        label {
            font-size: 14px;
            font-weight: 600;
            color: #000000;
        }

        input[type="text"],
        input[type="number"],
        input[type="date"],
        textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            font-size: 15px;
            outline: none;
            transition: border-color 0.2s;
            background-color: #ffffff;
        }

        input:focus, textarea:focus {
            border-color: #cbd5e1;
        }

        textarea {
            resize: vertical;
            min-height: 120px;
        }

        /* Sezione Valutazione */
        .rating-container {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 5px;
        }

        .rating-btn {
            width: 40px;
            height: 40px;
            border: 1px solid #e2e8f0;
            background-color: #ffffff;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .rating-btn:hover {
            background-color: #f8fafc;
            border-color: #cbd5e1;
        }

        .rating-btn.selected {
            background-color: #000000;
            color: #ffffff;
            border-color: #000000;
        }

        /* Pulsanti Azione */
        .buttons-group {
            display: flex;
            gap: 12px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .btn {
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #ffffff;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn:hover {
            opacity: 0.9;
        }

        .btn-docx {
            background-color: #2b579a;
        }

        .btn-clear {
            background-color: #4a4a4a;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header-title">📚 Identikit Libro Letto</div>
    
    <form id="book-form" onsubmit="return false;">
        <div class="grid-2col">
            <div class="input-group">
                <label for="titolo">Titolo</label>
                <input type="text" id="titolo">
            </div>
            <div class="input-group">
                <label for="autore">Autore del Libro</label>
                <input type="text" id="autore">
            </div>
        </div>

        <div class="grid-2col">
            <div class="input-group">
                <label for="anno">Anno di pubblicazione</label>
                <input type="text" id="anno">
            </div>
            <div class="input-group">
                <label for="genere">Genere</label>
                <input type="text" id="genere">
            </div>
        </div>

        <div class="grid-2col">
            <div class="input-group">
                <label for="data-lettura">Data lettura</label>
                <input type="date" id="data-lettura">
            </div>
            <div class="input-group">
                <label for="pagine">Numero pagine</label>
                <input type="number" id="pagine">
            </div>
        </div>

        <div class="input-group">
            <label for="trama">Trama (senza spoiler)</label>
            <textarea id="trama"></textarea>
        </div>

        <div class="input-group">
            <label for="personaggi">Personaggi principali</label>
            <textarea id="personaggi"></textarea>
        </div>

        <div class="input-group">
            <label>Valutazione</label>
            <div class="rating-container" id="rating-box">
                </div>
        </div>

        <div class="input-group">
            <label for="note">Note</label>
            <textarea id="note"></textarea>
        </div>

        <div class="input-group" style="margin-top: 10px;">
            <label for="firma">Identikit compilato da:</label>
            <input type="text" id="firma" placeholder="Inserisci il tuo nome">
        </div>

        <div class="buttons-group">
            <button type="button" class="btn btn-docx" id="btn-docx">Esporta DOCX</button>
            <button type="button" class="btn btn-clear" id="btn-clear">Pulisci</button>
        </div>
    </form>
</div>

<script src="script.js"></script>
</body>
</html>